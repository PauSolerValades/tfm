{
  "seed": null,
  "horizon": 10000,
  "duration": 9000,
  "warmup_time": 1000,
  "user_policy": {
    "categorical": {
      "weights": [0.60, 0.20, 0.15, 0.05 ],
      "data": [ "ignore", "like", "repost", "quote" ]
    }
  },
  "user_inter_action": {
    "exponential": {
      "mean": 3 
    }
  },
  "warmup_post_inter_creation": {
    "uniform": {
      "min": 0,
      "max": 1000,
      "interval": "oc"
    }
  },
  "post_inter_creation": {
    "exponential": {
      "mean": 20
    }
  },
  "propagation_delay": {
    "constant": {
      "value": 1
    }
  },
  "interaction_delay": { 
    "constant": {
      "value": 1
    }
  },
  "creation_delay": {
    "constant": {
      "value": 1
    }
  },
  "offline_startup_ratio": 0.5,
  "session_duration": {
    "exponential": {
      "mean": 60
    }
  },
  "user_inter_session": {
    "exponential": {
      "mean": 120
    }
  },
  "attend_offline_notification": 0.8,
  "trace_to_file": true
}
